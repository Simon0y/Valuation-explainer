# ---------------------------------------------------------------------------
# Financial Modeling Prep API key.
#
# LOCAL USE:
#   1. Copy this file to ".streamlit/secrets.toml" (same folder, drop ".example").
#   2. Replace the placeholder below with your real key.
#   The real secrets.toml is gitignored and will never be committed.
#
# STREAMLIT COMMUNITY CLOUD:
#   Do NOT commit your key. Instead paste the line below (with your real key)
#   into the app's  Advanced settings -> Secrets  box when you deploy, or later
#   under  app menu (⋮) -> Settings -> Secrets.
#
# Get a key at: https://financialmodelingprep.com/developer/docs
# ---------------------------------------------------------------------------

FMP_API_KEY = "your_fmp_api_key_here"

# ---------------------------------------------------------------------------
# Google Gemini API key — powers the AI Insights tab (free tier).
#   Get a key at: https://aistudio.google.com/apikey
#   Optional: the rest of the app works without it; only AI Insights needs it.
#   Like the FMP key, the real secrets.toml is gitignored and never committed.
# ---------------------------------------------------------------------------
GEMINI_API_KEY = "your_gemini_api_key_here"
